{{!
    @template local_moderndashboard/dashboard

    Modern Dashboard main template.

    Context variables required for this template:
    - firstname: string
    - fullname: string
    - userpictureurl: string
    - greeting: string
    - welcomemsg: string
    - showwelcome: bool
    - showstats: bool
    - showrecentactivity: bool
    - enabledarkmode: bool
    - totalcourses: int
    - completedcourses: int
    - inprogress: int
    - badges: int
    - activities: int
    - daysonline: int
    - courses: array
    - recentactivity: array
    - quickactions: array
    - primarycolor: string
    - secondarycolor: string
    - accentcolor: string
    - wwwroot: string
    - coursesurl: string

    Example context (json):
    {
        "firstname": "John",
        "fullname": "John Doe",
        "userpictureurl": "https://example.com/avatar.jpg",
        "greeting": "Good morning",
        "welcomemsg": "Welcome back, John!",
        "showwelcome": true,
        "showstats": true,
        "showrecentactivity": true,
        "enabledarkmode": true,
        "totalcourses": 5,
        "completedcourses": 2,
        "inprogress": 3,
        "badges": 4,
        "activities": 24,
        "daysonline": 12,
        "courses": [],
        "recentactivity": [],
        "quickactions": [],
        "primarycolor": "#2563eb",
        "secondarycolor": "#1e293b",
        "accentcolor": "#38bdf8",
        "wwwroot": "/",
        "coursesurl": "/my/courses.php"
    }
}}

<style>
  :root {
    --md-primary:    {{primarycolor}};
    --md-secondary:  {{secondarycolor}};
    --md-accent:     {{accentcolor}};
    --md-bg:         #f8fafc;
    --md-surface:    #ffffff;
    --md-border:     #e2e8f0;
    --md-text:       #0f172a;
    --md-text-muted: #64748b;
    --md-radius:     12px;
    --md-shadow:     0 1px 3px rgba(0,0,0,.06), 0 4px 16px rgba(0,0,0,.06);
    --md-shadow-lg:  0 4px 24px rgba(0,0,0,.1);
    --md-transition: all .22s cubic-bezier(.4,0,.2,1);
    --md-font:       'Inter', 'Poppins', system-ui, -apple-system, sans-serif;
  }

  body.moderndashboard-active.dark-mode {
    --md-bg:         #0f172a;
    --md-surface:    #1e293b;
    --md-border:     #334155;
    --md-text:       #f1f5f9;
    --md-text-muted: #94a3b8;
  }

  /* ---- Layout ---- */
  .md-dashboard {
    font-family: var(--md-font);
    background: var(--md-bg);
    min-height: 100vh;
    padding: 0 0 3rem;
    color: var(--md-text);
    transition: var(--md-transition);
  }

  /* ---- Welcome Banner ---- */
  .md-welcome {
    background: linear-gradient(135deg, var(--md-primary) 0%, #4f46e5 60%, var(--md-accent) 100%);
    border-radius: 0 0 24px 24px;
    padding: 2.5rem 2rem 3rem;
    margin-bottom: 2rem;
    position: relative;
    overflow: hidden;
    color: #fff;
  }
  .md-welcome::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 80% 20%, rgba(255,255,255,.12) 0%, transparent 60%);
    pointer-events: none;
  }
  .md-welcome__inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    position: relative;
    z-index: 1;
  }
  .md-welcome__avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: 3px solid rgba(255,255,255,.4);
    object-fit: cover;
    flex-shrink: 0;
    box-shadow: 0 4px 16px rgba(0,0,0,.2);
  }
  .md-welcome__greeting {
    font-size: .875rem;
    opacity: .85;
    margin: 0 0 .25rem;
    font-weight: 400;
    letter-spacing: .02em;
  }
  .md-welcome__name {
    font-size: 1.65rem;
    font-weight: 700;
    margin: 0 0 .35rem;
    line-height: 1.2;
  }
  .md-welcome__msg {
    font-size: .95rem;
    opacity: .8;
    margin: 0;
    font-weight: 400;
  }
  .md-welcome__actions {
    margin-left: auto;
    display: flex;
    gap: .75rem;
    flex-shrink: 0;
  }

  /* ---- Dark Mode Toggle ---- */
  .md-darkmode-btn {
    background: rgba(255,255,255,.15);
    border: 1px solid rgba(255,255,255,.25);
    color: #fff;
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: var(--md-transition);
    backdrop-filter: blur(8px);
    text-decoration: none;
  }
  .md-darkmode-btn:hover {
    background: rgba(255,255,255,.28);
    transform: scale(1.08);
  }
  .md-darkmode-btn svg {
    width: 18px; height: 18px;
    fill: currentColor;
  }

  /* ---- Container ---- */
  .md-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ---- Stats Grid ---- */
  .md-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }
  @media (max-width: 640px) {
    .md-stats { grid-template-columns: repeat(2, 1fr); }
  }
  .md-stat-card {
    background: var(--md-surface);
    border-radius: var(--md-radius);
    padding: 1.25rem;
    box-shadow: var(--md-shadow);
    border: 1px solid var(--md-border);
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: var(--md-transition);
  }
  .md-stat-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--md-shadow-lg);
  }
  .md-stat-card__icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    flex-shrink: 0;
  }
  .md-stat-card__icon--blue   { background: #dbeafe; color: #2563eb; }
  .md-stat-card__icon--green  { background: #dcfce7; color: #16a34a; }
  .md-stat-card__icon--purple { background: #f3e8ff; color: #9333ea; }
  .md-stat-card__icon--amber  { background: #fef9c3; color: #ca8a04; }
  .md-stat-card__icon--cyan   { background: #cffafe; color: #0891b2; }
  .md-stat-card__icon--rose   { background: #ffe4e6; color: #e11d48; }
  .md-stat-card__value {
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1;
    color: var(--md-text);
    margin: 0 0 .2rem;
  }
  .md-stat-card__label {
    font-size: .75rem;
    color: var(--md-text-muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: .06em;
    margin: 0;
  }

  /* ---- Section header ---- */
  .md-section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
    gap: 1rem;
  }
  .md-section-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--md-text);
    margin: 0;
  }
  .md-link-all {
    font-size: .85rem;
    color: var(--md-primary);
    text-decoration: none;
    font-weight: 500;
    white-space: nowrap;
    transition: var(--md-transition);
    display: flex;
    align-items: center;
    gap: .3rem;
  }
  .md-link-all:hover { opacity: .75; }

  /* ---- Course Grid ---- */
  .md-course-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }
  @media (max-width: 900px) {
    .md-course-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .md-course-grid { grid-template-columns: 1fr; }
  }

  /* ---- Course Card ---- */
  .md-course-card {
    background: var(--md-surface);
    border-radius: var(--md-radius);
    box-shadow: var(--md-shadow);
    border: 1px solid var(--md-border);
    overflow: hidden;
    transition: var(--md-transition);
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    position: relative;
  }
  .md-course-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--md-shadow-lg);
    border-color: var(--md-primary);
    text-decoration: none;
    color: inherit;
  }
  .md-course-card__thumb {
    width: 100%;
    height: 150px;
    object-fit: cover;
    background: linear-gradient(135deg, var(--md-primary), var(--md-accent));
    display: block;
    flex-shrink: 0;
  }
  .md-course-card__thumb-placeholder {
    width: 100%;
    height: 150px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 2.5rem;
    background: linear-gradient(135deg, var(--md-primary) 0%, var(--md-accent) 100%);
    color: #fff;
  }
  .md-course-card__badge {
    position: absolute;
    top: .75rem;
    left: .75rem;
    background: rgba(0,0,0,.45);
    backdrop-filter: blur(6px);
    color: #fff;
    font-size: .7rem;
    font-weight: 600;
    padding: .25rem .65rem;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: .05em;
  }
  .md-course-card__body {
    padding: 1.1rem 1.1rem .9rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .md-course-card__title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--md-text);
    line-height: 1.45;
    margin: 0 0 .6rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .md-course-card__teacher {
    display: flex;
    align-items: center;
    gap: .5rem;
    margin-bottom: .85rem;
  }
  .md-course-card__teacher-avatar {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--md-border);
    flex-shrink: 0;
  }
  .md-course-card__teacher-name {
    font-size: .8rem;
    color: var(--md-text-muted);
    font-weight: 500;
  }
  .md-course-card__progress {
    margin-top: auto;
  }
  .md-course-card__progress-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: .4rem;
  }
  .md-course-card__progress-label {
    font-size: .75rem;
    color: var(--md-text-muted);
    font-weight: 500;
  }
  .md-course-card__progress-pct {
    font-size: .75rem;
    font-weight: 700;
    color: var(--md-primary);
  }
  .md-progress-bar {
    height: 6px;
    border-radius: 999px;
    background: var(--md-border);
    overflow: hidden;
  }
  .md-progress-bar__fill {
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--md-primary), var(--md-accent));
    transition: width .6s ease;
  }
  .md-course-card__footer {
    padding: .75rem 1.1rem;
    border-top: 1px solid var(--md-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .md-course-card__startdate {
    font-size: .75rem;
    color: var(--md-text-muted);
  }
  .md-course-card__cta {
    background: var(--md-primary);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: .78rem;
    font-weight: 600;
    padding: .4rem .9rem;
    cursor: pointer;
    text-decoration: none;
    transition: var(--md-transition);
    display: inline-flex;
    align-items: center;
    gap: .3rem;
  }
  .md-course-card__cta:hover {
    background: #1d4ed8;
    color: #fff;
    text-decoration: none;
    transform: scale(1.04);
  }

  /* ---- No courses empty state ---- */
  .md-empty-courses {
    text-align: center;
    padding: 3rem 1rem;
    background: var(--md-surface);
    border-radius: var(--md-radius);
    border: 1px dashed var(--md-border);
    margin-bottom: 2rem;
  }
  .md-empty-courses__icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }
  .md-empty-courses__title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--md-text);
    margin: 0 0 .5rem;
  }
  .md-empty-courses__msg {
    color: var(--md-text-muted);
    font-size: .9rem;
    margin: 0 0 1.25rem;
  }

  /* ---- Bottom grid (activity + quick actions) ---- */
  .md-bottom-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 1.25rem;
    align-items: start;
  }
  @media (max-width: 820px) {
    .md-bottom-grid { grid-template-columns: 1fr; }
  }

  /* ---- Activity Feed ---- */
  .md-activity-feed {
    background: var(--md-surface);
    border-radius: var(--md-radius);
    box-shadow: var(--md-shadow);
    border: 1px solid var(--md-border);
    padding: 1.25rem;
  }
  .md-activity-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .md-activity-item {
    display: flex;
    align-items: flex-start;
    gap: .875rem;
    padding: .85rem 0;
    border-bottom: 1px solid var(--md-border);
  }
  .md-activity-item:last-child { border-bottom: none; }
  .md-activity-item__dot {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: #dbeafe;
    color: #2563eb;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: .9rem;
  }
  .md-activity-item__content { flex: 1; min-width: 0; }
  .md-activity-item__action {
    font-size: .88rem;
    font-weight: 600;
    color: var(--md-text);
    margin: 0 0 .15rem;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .md-activity-item__course {
    font-size: .8rem;
    color: var(--md-text-muted);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .md-activity-item__time {
    font-size: .75rem;
    color: var(--md-text-muted);
    flex-shrink: 0;
    margin-top: .2rem;
  }
  .md-no-activity {
    color: var(--md-text-muted);
    text-align: center;
    padding: 1.5rem;
    font-size: .9rem;
  }

  /* ---- Quick Actions ---- */
  .md-quick-actions {
    background: var(--md-surface);
    border-radius: var(--md-radius);
    box-shadow: var(--md-shadow);
    border: 1px solid var(--md-border);
    padding: 1.25rem;
  }
  .md-quick-actions__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: .75rem;
    margin-top: .5rem;
  }
  .md-quick-action {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: .5rem;
    padding: 1rem .5rem;
    border-radius: 12px;
    background: var(--md-bg);
    border: 1px solid var(--md-border);
    text-decoration: none;
    color: var(--md-text);
    font-size: .8rem;
    font-weight: 500;
    transition: var(--md-transition);
    text-align: center;
  }
  .md-quick-action:hover {
    background: var(--md-primary);
    color: #fff;
    border-color: var(--md-primary);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(37,99,235,.3);
    text-decoration: none;
  }
  .md-quick-action__icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
  }

  /* ---- Btn ---- */
  .md-btn {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    padding: .65rem 1.4rem;
    border-radius: 8px;
    font-size: .9rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: var(--md-transition);
  }
  .md-btn--primary {
    background: #fff;
    color: var(--md-primary);
  }
  .md-btn--primary:hover {
    background: rgba(255,255,255,.85);
    color: var(--md-primary);
    text-decoration: none;
    transform: scale(1.03);
  }
  .md-btn--outline {
    background: transparent;
    color: #fff;
    border: 1.5px solid rgba(255,255,255,.5);
  }
  .md-btn--outline:hover {
    background: rgba(255,255,255,.12);
    color: #fff;
    text-decoration: none;
  }
</style>

<div class="md-dashboard" id="md-dashboard-root">

  {{#showwelcome}}
  {{! ===== WELCOME BANNER ===== }}
  <div class="md-welcome" role="banner">
    <div class="md-welcome__inner">
      <img class="md-welcome__avatar"
           src="{{userpictureurl}}"
           alt="{{fullname}}"
           loading="lazy">
      <div>
        <p class="md-welcome__greeting">{{greeting}} 👋</p>
        <h1 class="md-welcome__name">{{fullname}}</h1>
        <p class="md-welcome__msg">{{welcomemsg}}</p>
      </div>
      <div class="md-welcome__actions">
        <a href="{{coursesurl}}" class="md-btn md-btn--primary">
          {{#str}}mylearning, local_moderndashboard{{/str}}
        </a>
        {{#enabledarkmode}}
        <button class="md-darkmode-btn"
                id="md-darkmode-toggle"
                title="{{#str}}darkmode, local_moderndashboard{{/str}}"
                aria-label="{{#str}}darkmode, local_moderndashboard{{/str}}">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
        {{/enabledarkmode}}
      </div>
    </div>
  </div>
  {{/showwelcome}}

  <div class="md-container">

    {{#showstats}}
    {{! ===== STATS GRID ===== }}
    <div class="md-stats" aria-label="Learning statistics">
      <div class="md-stat-card">
        <div class="md-stat-card__icon md-stat-card__icon--blue" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
          </svg>
        </div>
        <div>
          <p class="md-stat-card__value" data-md-stat="totalcourses">{{totalcourses}}</p>
          <p class="md-stat-card__label">{{#str}}totalcourses, local_moderndashboard{{/str}}</p>
        </div>
      </div>
      <div class="md-stat-card">
        <div class="md-stat-card__icon md-stat-card__icon--green" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
        </div>
        <div>
          <p class="md-stat-card__value" data-md-stat="completedcourses">{{completedcourses}}</p>
          <p class="md-stat-card__label">{{#str}}completedcourses, local_moderndashboard{{/str}}</p>
        </div>
      </div>
      <div class="md-stat-card">
        <div class="md-stat-card__icon md-stat-card__icon--amber" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/>
            <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
          </svg>
        </div>
        <div>
          <p class="md-stat-card__value" data-md-stat="inprogress">{{inprogress}}</p>
          <p class="md-stat-card__label">{{#str}}inprogress, local_moderndashboard{{/str}}</p>
        </div>
      </div>
      <div class="md-stat-card">
        <div class="md-stat-card__icon md-stat-card__icon--purple" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
        </div>
        <div>
          <p class="md-stat-card__value" data-md-stat="badges">{{badges}}</p>
          <p class="md-stat-card__label">{{#str}}badgesearned, local_moderndashboard{{/str}}</p>
        </div>
      </div>
      <div class="md-stat-card">
        <div class="md-stat-card__icon md-stat-card__icon--cyan" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
          </svg>
        </div>
        <div>
          <p class="md-stat-card__value" data-md-stat="activities">{{activities}}</p>
          <p class="md-stat-card__label">{{#str}}activitiesfinished, local_moderndashboard{{/str}}</p>
        </div>
      </div>
      <div class="md-stat-card">
        <div class="md-stat-card__icon md-stat-card__icon--rose" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
        </div>
        <div>
          <p class="md-stat-card__value" data-md-stat="daysonline">{{daysonline}}</p>
          <p class="md-stat-card__label">{{#str}}daysonline, local_moderndashboard{{/str}}</p>
        </div>
      </div>
    </div>
    {{/showstats}}

    {{! ===== MY COURSES ===== }}
    <div class="md-section-header">
      <h2 class="md-section-title">{{#str}}mylearning, local_moderndashboard{{/str}}</h2>
      {{#hascourses}}
      <a href="{{coursesurl}}" class="md-link-all" aria-label="{{#str}}viewallcourses, local_moderndashboard{{/str}}">
        {{#str}}viewallcourses, local_moderndashboard{{/str}}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </a>
      {{/hascourses}}
    </div>

    {{#hascourses}}
    <div class="md-course-grid" role="list" aria-label="Enrolled courses">
      {{#courses}}
      <a href="{{url}}" class="md-course-card" role="listitem"
         aria-label="{{fullname}} – {{progressint}}% complete">
        {{#categoryname}}
        <span class="md-course-card__badge">{{categoryname}}</span>
        {{/categoryname}}
        <img class="md-course-card__thumb"
             src="{{imageurl}}"
             alt="{{fullname}} course thumbnail"
             loading="lazy"
             onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
        <div class="md-course-card__thumb-placeholder" style="display:none;" aria-hidden="true">📚</div>

        <div class="md-course-card__body">
          <h3 class="md-course-card__title">{{fullname}}</h3>
          {{#teachername}}
          <div class="md-course-card__teacher">
            {{#teacherpicture}}
            <img class="md-course-card__teacher-avatar"
                 src="{{teacherpicture}}"
                 alt="{{teachername}}"
                 loading="lazy">
            {{/teacherpicture}}
            <span class="md-course-card__teacher-name">{{teachername}}</span>
          </div>
          {{/teachername}}
          <div class="md-course-card__progress">
            <div class="md-course-card__progress-header">
              <span class="md-course-card__progress-label">
                {{#str}}progress, local_moderndashboard{{/str}}
              </span>
              <span class="md-course-card__progress-pct">{{progressint}}%</span>
            </div>
            <div class="md-progress-bar" role="progressbar"
                 aria-valuenow="{{progressint}}"
                 aria-valuemin="0"
                 aria-valuemax="100">
              <div class="md-progress-bar__fill"
                   style="width:{{progressint}}%"
                   data-progress="{{progressint}}">
              </div>
            </div>
          </div>
        </div>

        <div class="md-course-card__footer">
          {{#startdate}}
          <span class="md-course-card__startdate">{{startdate}}</span>
          {{/startdate}}
          <span class="md-course-card__cta">
            {{#str}}continuecourse, local_moderndashboard{{/str}}
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </span>
        </div>
      </a>
      {{/courses}}
    </div>
    {{/hascourses}}

    {{^hascourses}}
    <div class="md-empty-courses" role="status">
      <div class="md-empty-courses__icon" aria-hidden="true">🎓</div>
      <p class="md-empty-courses__title">{{#str}}nocourses, local_moderndashboard{{/str}}</p>
      <p class="md-empty-courses__msg">Start your learning journey today.</p>
      <a href="{{coursesurl}}" class="md-course-card__cta">
        {{#str}}explorecourses, local_moderndashboard{{/str}}
      </a>
    </div>
    {{/hascourses}}

    {{! ===== BOTTOM GRID ===== }}
    <div class="md-bottom-grid">

      {{#showrecentactivity}}
      {{! ===== RECENT ACTIVITY ===== }}
      <div class="md-activity-feed" aria-label="Recent activity">
        <div class="md-section-header" style="margin-bottom:.75rem">
          <h2 class="md-section-title" style="font-size:1rem">
            {{#str}}recentactivity, local_moderndashboard{{/str}}
          </h2>
        </div>
        {{#hasrecentactivity}}
        <ul class="md-activity-list">
          {{#recentactivity}}
          <li class="md-activity-item">
            <div class="md-activity-item__dot" aria-hidden="true">
              {{#str}}action_{{action}}, local_moderndashboard{{/str}}
            </div>
            <div class="md-activity-item__content">
              <p class="md-activity-item__action">{{action}}</p>
              <p class="md-activity-item__course">
                <a href="{{courseurl}}" style="color:var(--md-text-muted);text-decoration:none;">
                  {{coursename}}
                </a>
              </p>
            </div>
            <span class="md-activity-item__time" aria-label="{{timeago}}">{{timeago}}</span>
          </li>
          {{/recentactivity}}
        </ul>
        {{/hasrecentactivity}}
        {{^hasrecentactivity}}
        <p class="md-no-activity">{{#str}}noactivity, local_moderndashboard{{/str}}</p>
        {{/hasrecentactivity}}
      </div>
      {{/showrecentactivity}}

      {{! ===== QUICK ACTIONS ===== }}
      <div class="md-quick-actions" aria-label="Quick actions">
        <h2 class="md-section-title" style="font-size:1rem;margin:0 0 .25rem">
          {{#str}}quickactions, local_moderndashboard{{/str}}
        </h2>
        <div class="md-quick-actions__grid">
          {{#quickactions}}
          <a href="{{url}}" class="md-quick-action"
             aria-label="{{label}}">
            <div class="md-quick-action__icon" aria-hidden="true">
              {{#str}}{{label}}, local_moderndashboard{{/str}}
            </div>
            <span>{{label}}</span>
          </a>
          {{/quickactions}}
        </div>
      </div>

    </div>{{! end bottom grid }}

  </div>{{! end md-container }}
</div>{{! end md-dashboard }}

