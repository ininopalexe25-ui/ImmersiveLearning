    @template mod_gear/leaderboard_table

    Example context (json):
    {
        "has_scores": true,
        "scores": [
            {"rank": 1, "badge": "🏆", "fullname": "John Doe", "score": 100},
            {"rank": 2, "badge": "🥈", "fullname": "Jane Smith", "score": 80}
        ]
    }
}}
{{#has_scores}}
<table class="table table-striped">
    <thead>
        <tr>
            <th>#</th>
            <th>{{#str}}user{{/str}}</th>
            <th>{{#str}}score, mod_gear{{/str}}</th>
        </tr>
    </thead>
    <tbody>
        {{#scores}}
        <tr>
            <td>{{rank}} {{badge}}</td>
            <td>{{fullname}}</td>
            <td><strong>{{score}}</strong></td>
        </tr>
        {{/scores}}
    </tbody>
</table>
{{/has_scores}}
{{^has_scores}}
<p class="text-muted text-center">{{#str}}noscores, mod_gear{{/str}}</p>
{{/has_scores}}
