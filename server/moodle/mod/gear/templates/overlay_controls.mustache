    @template mod_gear/overlay_controls

    Example context (json):
    {
        "cmid": 123
    }
}}
<div class="gear-scene-overlay" id="gear-scene-overlay-{{cmid}}">
    <div class="gear-hotspots-dropdown dropdown" id="gear-hotspots-nav-{{cmid}}">
        <button class="btn btn-secondary gear-control-btn gear-overlay-btn dropdown-toggle" type="button" 
                id="gear-hotspots-toggle-{{cmid}}" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false"
                title="{{#str}}hotspots, mod_gear{{/str}}">
            <i class="fa fa-map-marker-alt"></i>
        </button>
        <div class="dropdown-menu dropdown-menu-right gear-hotspots-menu" aria-labelledby="gear-hotspots-toggle-{{cmid}}">
            <!-- Dynamically populated -->
        </div>
    </div>

    <button class="btn btn-secondary gear-control-btn gear-overlay-btn" id="gear-leaderboard-btn-{{cmid}}" title="{{#str}}leaderboard, mod_gear{{/str}}">
        <i class="fa fa-trophy"></i>
    </button>

    <button class="btn btn-secondary gear-control-btn gear-overlay-btn" id="gear-voice-btn-{{cmid}}" type="button" title="{{#str}}joinvoice, mod_gear{{/str}}">
        <i class="fa fa-microphone-slash"></i>
    </button>

    <button class="btn btn-secondary gear-control-btn gear-overlay-btn" id="gear-chat-toggle-btn-{{cmid}}" type="button" title="{{#str}}toggle_chat, mod_gear{{/str}}">
        <i class="fa fa-comments"></i>
    </button>

    <button class="btn btn-secondary gear-control-btn gear-overlay-btn" id="gear-help-btn-{{cmid}}" type="button" title="{{#str}}help, mod_gear{{/str}}">
        <i class="fa fa-question"></i>
    </button>

    <!-- Chat Panel -->
    <div class="gear-chat-panel d-none" id="gear-chat-panel-{{cmid}}">
        <div class="gear-chat-header">
            <strong>{{#str}}chat, mod_gear{{/str}}</strong>
            <button type="button" class="close" id="gear-chat-close-{{cmid}}">&times;</button>
        </div>
        <div class="gear-chat-messages" id="gear-chat-messages-{{cmid}}"></div>
        <div class="gear-chat-input">
            <input type="text" class="form-control" id="gear-chat-input-{{cmid}}" placeholder="{{#str}}type_message, mod_gear{{/str}}">
            <button class="btn btn-primary" id="gear-chat-send-{{cmid}}"><i class="fa fa-paper-plane"></i></button>
        </div>
    </div>
</div>
