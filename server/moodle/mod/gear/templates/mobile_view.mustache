{{!
    @template mod_gear/mobile_view

    Mobile view template for mod_gear.

    @copyright  2026 Boban Blagojevic
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * name - Module name
    * intro - Module introduction
    * warning - Mobile usage warning

    Example context (json):
    {
        "name": "Explore Solar System",
        "intro": "<p>Welcome to the VR simulation.</p>",
        "warning": "This content is optimized for the Moodle app."
    }
}}
<div>
    {{#name}}<h3>{{{name}}}</h3>{{/name}}
    <div class="intro">
        {{{intro}}}
    </div>
    <div class="alert alert-info">
        {{warning}}
    </div>
    <!-- In the future, we can embed a simplified 3D viewer here or a button to open in browser -->
    <div class="gear-mobile-placeholder mt-3">
        <p>This activity provides immersive 3D content.</p>
    </div>
</div>
