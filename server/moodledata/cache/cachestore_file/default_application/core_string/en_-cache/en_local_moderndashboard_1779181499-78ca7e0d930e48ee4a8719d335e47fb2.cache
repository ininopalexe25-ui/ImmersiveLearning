a:56:{s:10:"pluginname";s:16:"Modern Dashboard";s:12:"primarycolor";s:13:"Primary Color";s:17:"primarycolor_desc";s:57:"Main brand color used for buttons, links, and highlights.";s:14:"secondarycolor";s:15:"Secondary Color";s:19:"secondarycolor_desc";s:47:"Used for backgrounds and secondary UI elements.";s:11:"accentcolor";s:12:"Accent Color";s:16:"accentcolor_desc";s:33:"Used for hover states and badges.";s:12:"courseslimit";s:18:"Courses to Display";s:17:"courseslimit_desc";s:52:"Number of enrolled courses to show on the dashboard.";s:11:"showwelcome";s:19:"Show Welcome Banner";s:16:"showwelcome_desc";s:66:"Display a personalized welcome banner at the top of the dashboard.";s:9:"showstats";s:15:"Show Statistics";s:14:"showstats_desc";s:39:"Display user learning statistics cards.";s:18:"showrecentactivity";s:20:"Show Recent Activity";s:23:"showrecentactivity_desc";s:52:"Display a recent activity timeline on the dashboard.";s:14:"enabledarkmode";s:23:"Enable Dark Mode Toggle";s:19:"enabledarkmode_desc";s:50:"Allow users to toggle between light and dark mode.";s:14:"welcomemessage";s:15:"Welcome Message";s:19:"welcomemessage_desc";s:83:"Personalized welcome message shown in the banner. Use {firstname} as a placeholder.";s:14:"welcomedefault";s:54:"Welcome back, {firstname}! Ready to continue learning?";s:11:"goodmorning";s:12:"Good morning";s:13:"goodafternoon";s:14:"Good afternoon";s:11:"goodevening";s:12:"Good evening";s:10:"mylearning";s:11:"My Learning";s:14:"continuecourse";s:8:"Continue";s:14:"viewallcourses";s:16:"View All Courses";s:14:"recentactivity";s:15:"Recent Activity";s:10:"noactivity";s:25:"No recent activity found.";s:9:"nocourses";s:40:"You are not enrolled in any courses yet.";s:14:"explorecourses";s:15:"Explore Courses";s:12:"totalcourses";s:13:"Total Courses";s:16:"completedcourses";s:9:"Completed";s:10:"inprogress";s:11:"In Progress";s:12:"badgesearned";s:13:"Badges Earned";s:18:"activitiesfinished";s:15:"Activities Done";s:10:"daysonline";s:11: